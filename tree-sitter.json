{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "reef",
      "camelcase": "reef",
      "title": "reef",
      "scope": "source.reef",
      "file-types": [
        "rf"
      ],
      "injection-regex": "^reef$",
      "class-name": "TreeSitterReef"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree sitter grammer for the reef language",
    "authors": [
      {
        "name": "Malachi Mackie",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/malachiMackie/tree-sitter-reef",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}